{
  "expo": {
    "name": "GoHustlr",
    "slug": "GoHustlr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gohustlr.app"
    },
    "android": {
      "package": "com.gohustlr.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.gohustlr",
          "enableGooglePay": false
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "GoHustlr needs access to your photos so you can set a profile picture and add job completion photos."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#6D28D9"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d5ff08f5-93f2-43f8-addb-67df36d564b6"
      }
    },
    "owner": "chrismalson"
  }
}
